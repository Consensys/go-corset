const OOB_INST_JUMP                             = 0x56
const OOB_INST_JUMPI                            = 0x57
const OOB_INST_RDC                              = 0x3E
const OOB_INST_CDL                              = 0x35
const OOB_INST_XCALL                            = 0xCC
const OOB_INST_CALL                             = 0xCA
const OOB_INST_XCREATE                          = 0xCD
const OOB_INST_CREATE                           = 0xCE
const OOB_INST_SSTORE                           = 0x55
const OOB_INST_DEPLOYMENT                       = 0xF3
const OOB_INST_ECRECOVER                        = 0xFF01
const OOB_INST_SHA2                             = 0xFF02
const OOB_INST_RIPEMD                           = 0xFF03
const OOB_INST_IDENTITY                         = 0xFF04
const OOB_INST_ECADD                            = 0xFF06
const OOB_INST_ECMUL                            = 0xFF07
const OOB_INST_ECPAIRING                        = 0xFF08
const OOB_INST_BLAKE_CDS                        = 0xFA09
const OOB_INST_BLAKE_PARAMS                     = 0xFB09
const OOB_INST_MODEXP_CDS                       = 0xFA05
const OOB_INST_MODEXP_XBS                       = 0xFB05
const OOB_INST_MODEXP_LEAD                      = 0xFC05
const OOB_INST_MODEXP_PRICING                   = 0xFD05
const OOB_INST_MODEXP_EXTRACT                   = 0xFE05
const OOB_INST_POINT_EVALUATION                 = 0xFF0A
const OOB_INST_BLS_G1_ADD                       = 0xFF0B
const OOB_INST_BLS_G1_MSM                       = 0xFF0C
const OOB_INST_BLS_G2_ADD                       = 0xFF0D
const OOB_INST_BLS_G2_MSM                       = 0xFF0E
const OOB_INST_BLS_PAIRING_CHECK                = 0xFF0F
const OOB_INST_BLS_MAP_FP_TO_G1                 = 0xFF10
const OOB_INST_BLS_MAP_FP2_TO_G2                = 0xFF11

;; The Out-Of-Bounds (OOB) module performs various "out of bounds" and
;; related checks.  Unfortunately, it is a hodge-podge of different
;; checks for different instrucitons, and a key aspect of what this
;; function does is dispatch based on the instruction to the relevant
;; set of checks.
pub fn oob(INST=0x56 u8, DATA_1 u128, DATA_2 u128, DATA_3 u128, DATA_4 u128, DATA_5 u128, DATA_6 u128, DATA_7=0x1 u128, DATA_8 u128, DATA_9 u128) {
   var tmp1, tmp2 u128
   ;;
   if INST == OOB_INST_JUMP goto oob_jump
   if INST == OOB_INST_JUMPI goto oob_jumpi
   fail

   ;; ==========================================================================
   ;; JUMP / JUMPI
   ;; ==========================================================================
oob_jumpi:
   ;; DATA_1::DATA_2 = pc_new
   ;; DATA_3::DATA_4 = jump_condition
   ;; DATA_5         = code_size
   ;; DATA_6         = jump_not_attempted
   ;; DATA_7         = jump_guaranteed_exception
   ;; DATA_8         = jump_must_be_attempted
   if DATA_3 != 0 goto oob_jumpi_attempted
   if DATA_4 != 0 goto oob_jumpi_attempted
   ;; condition==0 ==> jump not attempted
   if DATA_6 != 1 goto exit_f
   ;;
   return
oob_jumpi_attempted:
   if DATA_6 != 0 goto exit_f
   ;; fall thru
oob_jump:
   ;; DATA_1::DATA_2 = pc_new
   ;; DATA_5         = code_size
   ;; DATA_7         = jump_guaranteed_exception
   ;; DATA_8         = jump_must_be_attempted
   tmp1, tmp2 = check_jump_target(DATA_1, DATA_2, DATA_5)
   ;;
   if tmp1 != DATA_7 goto exit_f
   if tmp2 != DATA_8 goto exit_f
   ;;
   return

   ;; ==========================================================================
   ;; RETURN DATA COPY (RDC)
   ;; ==========================================================================

exit_f:
   fail
}

;; Check whether or not a jump target is within bounds pc_hi::pc_lo <
;; code_size.
fn check_jump_target(pc_hi u128, pc_lo u128, code_size u128) -> (jmp_ex=0x1 u1, jmp_mba u1) {
  var b u1
  var tmp u128
  ;; high word must be 0
  if pc_hi != 0 goto exit_f
  ;; compare low word
  b, tmp = code_size - pc_lo - 1
  ;; pc_lo >= code_size ?
  if b != 0 goto exit_f
  ;; must attempt
  jmp_ex = 0
  jmp_mba = 1
  return
exit_f:
  ;; exception
  jmp_ex = 1
  jmp_mba = 0
  return
}
