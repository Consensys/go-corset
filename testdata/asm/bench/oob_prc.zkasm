include "evm.zkasm"

;; type 1
const OOB_INST_ECRECOVER                        = 0xFF01 ;; 65281
const OOB_INST_SHA2                             = 0xFF02 ;; 65282
const OOB_INST_RIPEMD                           = 0xFF03 ;; 65283
const OOB_INST_IDENTITY                         = 0xFF04 ;; 65284
const OOB_INST_ECADD                            = 0xFF06 ;; 65286
const OOB_INST_ECMUL                            = 0xFF07 ;; 65287
;; type 2
const OOB_INST_ECPAIRING                        = 0xFF08 ;; 65288
const OOB_INST_POINT_EVALUATION                 = 0xFF0A ;; 65290
const OOB_INST_BLS_G1_ADD                       = 0xFF0B ;; 65291
const OOB_INST_BLS_G1_MSM                       = 0xFF0C ;; 65292
const OOB_INST_BLS_G2_ADD                       = 0xFF0D ;; 65293
const OOB_INST_BLS_G2_MSM                       = 0xFF0E ;; 65294
const OOB_INST_BLS_PAIRING_CHECK                = 0xFF0F ;; 65295
const OOB_INST_BLS_MAP_FP_TO_G1                 = 0xFF10 ;; 65296
const OOB_INST_BLS_MAP_FP2_TO_G2                = 0xFF11 ;; 65297
;; other
const OOB_INST_BLAKE_CDS                        = 0xFA09 ;; 64009
const OOB_INST_BLAKE_PARAMS                     = 0xFB09 ;; 64265
const OOB_INST_MODEXP_CDS                       = 0xFA05 ;; 64005
const OOB_INST_MODEXP_XBS                       = 0xFB05 ;; 64261
const OOB_INST_MODEXP_LEAD                      = 0xFC05 ;; 64517
const OOB_INST_MODEXP_PRICING                   = 0xFD05 ;; 64773
const OOB_INST_MODEXP_EXTRACT                   = 0xFE05 ;; 65029

;; The Out-Of-Bounds Precompiles (OOBPRC) module performs various "out
;; of bounds" and related checks for the various precompile calls.  A
;; key aspect of what this function does is dispatch based on the
;; instruction to the relevant set of checks.
;;
;; -------------------------------------------------------------------
;; ECRECOVER / SHA2 / RIPEMD / IDENT / ECADD / ECMUL (type 1)
;; -------------------------------------------------------------------
;; DATA_1 = callee_gas
;; DATA_2 = call_data_size (cds)
;; DATA_3 = return_at_capacity (r@c)
;; DATA_4 = hub_success
;; DATA_5 = return_gas
;; DATA_6 = extract_call_data
;; DATA_7 = empty_call_data
;; DATA_8 = r@c_non_zero
;;
;; -------------------------------------------------------------------
;; ECPAIRING / POINTEVAL / BLS_XXX (type 2)
;; -------------------------------------------------------------------
fn oob_prc(INST=0xFF01 u16, DATA_1 u128, DATA_2 u128, DATA_3 u128, DATA_4 u128, DATA_5 u128, DATA_6 u128, DATA_7 u128, DATA_8 u128, DATA_9 u128, DATA_10 u128) -> (dummy=1 u1) {
  var success, extract_cd, empty_cd, rc_nz, return_gas u128
  var cds u32
  var tmp u96
  var inst_hi, inst_lo u8
  ;; split instruction
  inst_hi, inst_lo = INST
  ;; type 1 & 2 checks
  if inst_hi == 0xFF goto oob_type12
  ;; others
  fail

oob_type12:
  ;; cast call_data_size
  tmp,cds = DATA_2
  if tmp != 0 goto exit_f
  ;;
  success,return_gas,extract_cd, empty_cd, rc_nz = oob_prc_type12(INST, DATA_1, cds, DATA_3)
  ;; check predictions
  if success != DATA_4 goto exit_f
  if return_gas != DATA_5 goto exit_f
  if extract_cd != DATA_6 goto exit_f
  if empty_cd != DATA_7 goto exit_f
  if rc_nz != DATA_8 goto exit_f
  ;; passed
  goto exit_s

exit_s:
  dummy = 1
  return
exit_f:
  fail
}

;; Perform required calculations for type 1 & 2 precompiles.
fn oob_prc_type12(inst=0xFF01 u16, callee_gas u128, cds u32, r_c u128) -> (hub_success u1, return_gas u128, extract_call_data u1, empty_call_data u1, rc_nz u1) {
  var delta, gas_cost u128
  var cds_valid u1
  var b u1
  ;; calculate r@c != 0
  rc_nz = r_c != 0 ? 1 : 0
  ;; cds validity
  cds_valid = oob_cds_valid(inst,cds)
  if cds_valid == 0 goto exit_f
  ;; calculate gas_cost
  gas_cost = oob_gas_cost(inst, cds)
  ;; check gas_cost <= callee_gas
  b, delta = callee_gas - gas_cost
  if b != 0 goto exit_f
  hub_success = 1
  return_gas = delta
  extract_call_data = cds != 0 ? 1 : 0
  empty_call_data = 1 - extract_call_data
  return
exit_f:
  hub_success = 0
  return_gas = 0
  extract_call_data = 0
  empty_call_data = 0
  return
}

;; Perform call_data_size (cds) validity checking as needed for the
;; instruction.  Observe that only a few instructions have
;; validity checks (e.g. for example, the ECPAIRING precompile
;; requires that cds%192==0.
fn oob_cds_valid(INST=0xFF01 u16, call_data_size u32) -> (cds_valid=1 u1) {
  var quot, rem u32
  var divisor u16
  ;;
  if INST == OOB_INST_ECPAIRING goto cds_mod192
  if INST == OOB_INST_BLAKE_CDS goto cds_213
  if INST == OOB_INST_POINT_EVALUATION goto cds_192
  if INST == OOB_INST_BLS_G1_ADD goto cds_256
  if INST == OOB_INST_BLS_G2_ADD goto cds_512
  if INST == OOB_INST_BLS_MAP_FP_TO_G1 goto cds_64
  if INST == OOB_INST_BLS_MAP_FP2_TO_G2 goto cds_128
  if INST == OOB_INST_BLS_G1_MSM goto cds_mod160
  if INST == OOB_INST_BLS_G2_MSM goto cds_mod288
  if INST == OOB_INST_BLS_PAIRING_CHECK goto cds_mod384
  ;; default case
  goto exit_s
cds_64:
  if call_data_size == 64 goto exit_s
  goto exit_f
cds_128:
  if call_data_size == 128 goto exit_s
  goto exit_f
cds_192:
  if call_data_size == 192 goto exit_s
  goto exit_f
cds_213:
  if call_data_size == 213 goto exit_s
  goto exit_f
cds_256:
  if call_data_size == 256 goto exit_s
  goto exit_f
cds_512:
  if call_data_size == 512 goto exit_s
  goto exit_f
cds_mod160:
  fail
cds_mod192:
  ;; check cds%192==0
  divisor = 192
  goto cds_mod
cds_mod288:
  ;; check cds%288==0
  divisor = 288
  goto cds_mod
cds_mod384:
  ;; check cds%384==0
  divisor = 384
  goto cds_mod
cds_mod:
  ;; compute cds%288
  quot,rem = div(call_data_size, divisor)
  ;; check cds%288==0
  if rem==0 goto exit_s
  goto exit_f
exit_f:
  cds_valid = 0
  return
exit_s:
  cds_valid = 1
  return
}

;; Compute the gas cost for a given precompile
fn oob_gas_cost(INST=0xFF01 u16, call_data_size u32) -> (gas_cost=3000 u128) {
  var d u126
  var k,r,c u32
  var discount u16
  ;;
  if INST == OOB_INST_ECRECOVER goto ecrecover
  if INST == OOB_INST_SHA2 goto sha2
  if INST == OOB_INST_RIPEMD goto ripemd
  if INST == OOB_INST_IDENTITY goto identity
  if INST == OOB_INST_ECADD goto ecadd
  if INST == OOB_INST_ECMUL goto ecmul
  if INST == OOB_INST_ECPAIRING goto ecpairing
  if INST == OOB_INST_BLAKE_CDS goto blake
  if INST == OOB_INST_MODEXP_PRICING goto modexp
  if INST == OOB_INST_POINT_EVALUATION goto pointeval
  if INST == OOB_INST_BLS_G1_ADD goto bls_g1add
  if INST == OOB_INST_BLS_G2_ADD goto bls_g2add
  if INST == OOB_INST_BLS_MAP_FP_TO_G1 goto bls_mapfpg1
  if INST == OOB_INST_BLS_MAP_FP2_TO_G2 goto bls_mapfp2g2
  if INST == OOB_INST_BLS_G1_MSM goto bls_g1msm
  if INST == OOB_INST_BLS_G2_MSM goto bls_g2msm
  if INST == OOB_INST_BLS_PAIRING_CHECK goto bls_pairing
  fail
ecrecover:
  gas_cost = G_ECDSA
  return
sha2:
  d = ceil_div(call_data_size,32)
  c,gas_cost = 60 + (12 * d)
  return
ripemd:
  d = ceil_div(call_data_size,32)
  c,gas_cost = 600 + (120 * d)
  return
identity:
  d = ceil_div(call_data_size,32)
  gas_cost = 15 + (3 * d)
  return
ecadd:
  gas_cost = G_BNADD
  return
ecmul:
  gas_cost = G_BNMUL
  return
ecpairing:
  d,r = div(call_data_size, 192)
  c,gas_cost = (d * 34000) + 45000
  return
blake:
modexp:
  fail
pointeval:
  gas_cost = G_POINT_EVALUATION
  return
bls_g1add:
  gas_cost = G_BLS_G1_ADD
  return
bls_g2add:
  gas_cost = G_BLS_G2_ADD
  return
bls_mapfpg1:
  gas_cost = G_BLS_MAP_FP_TO_G1
  return
bls_mapfp2g2:
  gas_cost = G_BLS_MAP_FP2_TO_G2
  return
bls_g1msm:
  k,r = div(call_data_size, 160)
  discount = g1_discount(k)
  gas_cost,c = div(k * G_BLS_G1_MSM_MULTIPLICATION_COST * discount, 1000)
  return
bls_g2msm:
  k,r = div(call_data_size, 288)
  discount = g2_discount(k)
  gas_cost,c = div(k * G_BLS_G2_MSM_MULTIPLICATION_COST * discount, 1000)
  return
bls_pairing:
  fail
}

fn g1_discount(k u126) -> (discount u16) {
  fail
}

fn g2_discount(k u126) -> (discount u16) {
  fail
}

;; poor mans division operator (to be deprecated)
fn div(val u32, divisor u16) -> (quotient u32, remainder u8) {
  var k, acc, rem, tmp u32
  var tmp2 u24
  var b1, b2, c1, c2 u1
  ;;
  acc = 0
  k = 0
  ;;
loop:
  ;; invariant acc <= val
  b1, rem = val - acc
  b2, tmp = divisor - 1 - rem
  if b2 == 0 goto exit
  ;;
  c1, acc = acc + divisor
  c2, k = k + 1
  goto loop
exit:
  quotient = k
  tmp2, remainder = rem
  return
}

;; compute ⌈x / y⌉ for y==8 or y==32
fn ceil_div(x u32, y=32 u6) -> (res u30) {
  var hi u29
  var lo8 u3
  var lo32 u5
  ;; check which type
  if y == 8 goto div8
  if y == 32 goto div32
  fail
div8:
  hi,lo8 = x
  ;; apply ceil
  if lo8 != 0 goto round_up
  goto exact
div32:
  hi,lo32 = x
  ;; apply ceil
  if lo32 != 0 goto round_up
exact:
  res = hi
  return
round_up:
  res = hi + 1
  return
}
