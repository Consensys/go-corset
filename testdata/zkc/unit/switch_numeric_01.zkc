type exmp = u16

// tests to test valid albeit pathological switch statements
//  * empty or not
//  * default present or not
//  * position of the default keyword
fn main() {

  var discr :exmp = 65535

  // no match
  switch discr {
    case 13: { fail }
  }
  switch discr {
    case 13: { fail }
    default: {}
  }

  // no match
  switch discr {
    case 13, 33: { fail }
  }
  switch discr {
    case 13, 33: { fail }
    default: {}
  }

  // no match
  switch discr {
    case 13: { fail }
    case 33: { fail }
  }
  switch discr {
    default: { fail}
    case 13: { fail }
    case 65535: { }
  }

  printf "success"
}
