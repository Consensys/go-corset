const CASE_A:u8 = 1
const CASE_B:u8 = 2
const CASE_C:u8 = 3
const CASE_D:u8 = 4

// standard switch case statement with function call discriminant
fn main() {

  var arg :u8 = 1

  switch get_case(arg) {
    case 0: {
      arg = arg + 1
    }
    case CASE_A, CASE_B: {
    deal_with(arg)
    }
    case CASE_C: {
    deal_with(arg + 1)
    }
    default: {
    deal_with(arg + 2)
    }
  }
}

fn get_case(arg :u8) -> (res :u8) {
  res = arg ^ 0xff
}

fn deal_with(discr :u8) {
  var variable :u8 = 128
  switch get_case(discr) {
    case CASE_A, CASE_B: {
      variable = discr * discr
    }
    case CASE_C: {
      variable = variable + discr
    }
    default: {
      variable = (discr + 14) >> 3
    }
  }
}
