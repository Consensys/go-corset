// ======================================================================
// unknown variable when the discriminant comes from a function argument
// ======================================================================

fn main() {
    var x:u32 = 12
    var y:u32 = 42

    var fffx:u32
    var gggy:u32

    fffx = fff(x)
    gggy = ggg(y)
}

fn fff(x:u32) -> (r:u32) {
    var y:u32 = x
    switch y {
        default: {
            r = x
            return
        }
    }
}

fn ggg(x:u32) -> (r:u32) {
    switch x {
        default: {
            r = x
            return
        }
    }
}
