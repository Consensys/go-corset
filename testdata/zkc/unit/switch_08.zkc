// ======================================================================
// unknown variable when the discriminant comes from a function argument
// ======================================================================

fn main() {
    var x:u32 = 12
    var y:u32 = 42

    var ffx:u32
    var ggy:u32

    ffx = ff(x)
    ggy = gg(y)
}

fn ff(x:u32) -> (r:u32) {
    var y:u32 = x
    switch y {
        default: {
            r = x
            return
        }
    }
}

fn gg(x:u32) -> (r:u32) {
    switch x {
        default: {
            r = x
            return
        }
    }
}
