pub input vA_input(address:u1) -> (word:u64)
pub input vB_input(address:u1) -> (word:u64)
pub input vC_input(address:u1) -> (word:u64)
pub input vD_input(address:u1) -> (word:u64)
pub input x(address:u1) -> (word:u64)
pub input y(address:u1) -> (word:u64)
pub output vA_out(address:u1) -> (word:u64)
pub output vB_out(address:u1) -> (word:u64)
pub output vC_out(address:u1) -> (word:u64)
pub output vD_out(address:u1) -> (word:u64)

// buffer to compute intermediary values for v
memory v_buffer(address:u2)-> (word:u64)

const MASK_u64:u128 = 0xFFFFFFFFFFFFFFFF

fn main<v_buffer>() {
    // g1
    v_buffer[0] = (( vA_input[0] as u128 + vB_input[0] as u128 + x[0] as u128 ) & MASK_u64) as u64
    v_buffer[3] = (( vD_input[0] ^ v_buffer[0] ) >> 32) | (( vD_input[0] ^ v_buffer[0] ) << 32)
    v_buffer[2] = (( vC_input[0] as u128 + v_buffer[3]  as u128 ) & MASK_u64) as u64
    v_buffer[1] = (( vB_input[0] ^ v_buffer[2] ) >> 24) | (( vB_input[0] ^ v_buffer[2] ) << 40)
    // g2
    v_buffer[0] = ((v_buffer[0] as u128 + v_buffer[1] as u128 + y[0] as u128) & MASK_u64) as u64
    v_buffer[3] = (( v_buffer[3] ^ v_buffer[0] ) >> 16) | (( v_buffer[3] ^ v_buffer[0] ) << 48)
    v_buffer[2] = (( v_buffer[2] as u128 + v_buffer[3] as u128 ) & MASK_u64) as u64
    v_buffer[1] = (( v_buffer[1] ^ v_buffer[2] ) >> 63) | (( v_buffer[1] ^ v_buffer[2] ) << 1)
    // result
    vA_out[0] = v_buffer[0]
    vB_out[0] = v_buffer[1]
    vC_out[0] = v_buffer[2]
    vD_out[0] = v_buffer[3]
}