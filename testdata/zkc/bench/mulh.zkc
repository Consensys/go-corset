include "hi_32_bits.zkc"

pub input data(address:u1)->(data:u32)
pub output product(address:u1)->(product:u32)

fn main() {
  product[0] = mulh(data[0],data[1])
  return
}

fn mulh(a:u32,b:u32) -> (c:u32) {
   var a_tmp:u64 = a as u64
   var b_tmp:u64 = b as u64
   var c_tmp:u64 = a_tmp * b_tmp
   c = hi_32_bits(c_tmp)
   return
}
