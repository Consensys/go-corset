include "../../impl/felt/poseidon.zkc"
include "../../impl/felt/state.zkc"
include "../../impl/felt/_results.zkc"
include "../../utils/memory.zkc"

// ===================================================================
// poseidon
// ===================================================================

const NUMBER_OF_FELTS_IN_RANGE:u32 = 1

fn main<ram, felt_state>() {

    // we write a message to RAM that will translate to 256 consecutive "0 ∈ 𝔽"
    //
    //    00 00 00     ⇒     0 ∈ 𝔽
    //    00 00 00     ⇒     0 ∈ 𝔽
    //     ⋮  ⋮  ⋮     ⇒     ⋮
    //    00 00 00     ⇒     0 ∈ 𝔽
    //
    // to memory.
    for i:Address = 0; i<(255 as Address); i = i + 1 {
        write_8(i * (BYTES_PER_FELT as Address), 0 as u8)
    }

    var message_offset:Address = 0
    var message_size_in_bytes:u32 = NUMBER_OF_FELTS_IN_RANGE * (BYTES_PER_FELT as u32)

    poseidon(message_offset, message_size_in_bytes, 256, 0)


    for i:u8 = 0; i<STATE_WIDTH; i = i + 1 {
        if results_poseidon_zeros_1(i) != read_from_state(i) {
            printf "\tω[%x] = %x,\tσ[%x] = %x\n", i, results_poseidon_zeros_1(i), i, read_from_state(i)
            fail
        }
    }
}
