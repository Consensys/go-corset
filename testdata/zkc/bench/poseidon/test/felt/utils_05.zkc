include "../../impl/felt/poseidon.zkc"
include "../../impl/felt/state.zkc"
include "../../utils/memory.zkc"

// ===================================================================
// read_from_tmp test
// ===================================================================

fn main<ram, state>() {
    // we write the message 0x00 01 02 ... fe ff into memory
    write_to_tmp(1, 1)
    var before_wipe:u32 = read_from_tmp(1)
    wipe_tmp()
    var after_wipe:u32 = read_from_tmp(1)

    if before_wipe != 1 {
        fail
    }
    if after_wipe != 0 {
        fail
    }
}
