include "../zkc/poseidon_uX.zkc"
include "../zkc/utils.zkc"
include "../zkc/types.zkc"

// ===================================================================
// write_8 test
// ===================================================================

fn main<ram, state>() {
    // we write the message 0x00 01 02 ... fe ff into memory
    for i:u8 = 0; i<16; i = i + 1 {
        write_8((i * 4) as Address, i as u8)
    }
    var one:u8 = ram[4]
    if one != 1 {
        fail
    }
}
