include "../../impl/u32/poseidon.zkc"
include "../../impl/u32/state.zkc"
include "../../impl/u32/_results.zkc"
include "../../utils/memory.zkc"

// ===================================================================
// poseidon
// ===================================================================

input expected_output_state(index:u8) -> (res:u32)

fn main<ram, u32_state>() {

    // we write the message
    //
    // 0x00 01 02 ... fe ff
    //
    // into memory
    for i:Address = 0; i<16; i = i + 1 {
        write_8(i, i as u8)
    }

    var message_size:u32 = 16
    var message_offset:Address = 0

    poseidon(message_offset, message_size, 256, 0)

    print_state()

    print_expected_output()
}

fn print_expected_output() {
    printf "\nExpected output\n"
    for i:u8 = 0; i<STATE_WIDTH; i = i + 1 {
        printf "ω[%x] = %x\n", i, expected_output_state(i)
    }
}
