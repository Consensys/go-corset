include "../../impl/u32/poseidon.zkc"
include "../../impl/u32/state.zkc"
include "../../impl/u32/_results.zkc"
include "../../utils/memory.zkc"

// ===================================================================
// poseidon
// ===================================================================

const NUMBER_OF_FELTS:u32 = 1 << 16

fn main<ram, u32_state>() {

    var message_offset:Address = 0
    var message_size_in_bytes:u32 = NUMBER_OF_FELTS * (BYTES_PER_FELT as u32)

    poseidon(message_offset, message_size_in_bytes, 256, 0)

    for i:u8 = 0; i<STATE_WIDTH; i = i + 1 {
        if results_poseidon_zeros_65536(i) != read_from_state(i) {
            printf "\tω[%x] = %x,\tσ[%x] = %x\n", i, results_poseidon_zeros_65536(i), i, read_from_state(i)
            fail
        }
    }
}
