include "../zkc/poseidon_uX.zkc"
include "../zkc/utils.zkc"
include "../zkc/types.zkc"

// ===================================================================
// read_from_tmp test
// ===================================================================

fn main<ram, state>() {
    // we write the message 0x00 01 02 ... fe ff into memory
    var zero:u32 = read_from_tmp(1)
    write_to_tmp(1, 1)
    var one:u32 = read_from_tmp(1)

    if zero != 0 {
        fail
    }
    if one != 1 {
        fail
    }
}
