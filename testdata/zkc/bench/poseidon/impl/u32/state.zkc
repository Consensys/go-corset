include "poseidon.zkc"

// state is defined as an array of u32's (emulating KOALABEAR field elements)
// of length STATE_WIDTH × 2, which looks like so:
//
//    [ σ₀, σ₁, ..., σₙ │ τ₀, τ₁, ..., τₙ]
//
// where n ≡ STATE_WIDTH, the σ-part of the state holds the actual Poseidon state,
// and the τ-part of the state is meant as temporary storage for operations
// updating the full Poseidon state.
memory u32_state(index:u8) -> (st:u32)

fn write_to_state<u32_state>(address:u8, value:u32) -> () {
    u32_state[address] = value
}

fn read_from_state<u32_state>(address:u8) -> (value:u32) {
    value = u32_state[address]
    return
}

fn write_to_tmp<u32_state>(address:u8, value:u32) -> () {
    u32_state[address + STATE_WIDTH] = value
}

fn read_from_tmp<u32_state>(address:u8) -> (value:u32) {
    value = u32_state[address + STATE_WIDTH]
    return
}

fn wipe_tmp<u32_state>() {
    for i:u8 = 0; i<STATE_WIDTH; i = i + 1 {
        u32_state[i + STATE_WIDTH] = 0
    }
}

fn state_to_ram<ram, u32_state>(address:Address, index:u8) -> (address_updt:Address) {
    var b3:u8
    var b2:u8
    var b1:u8
    var b0:u8
    b3::b2::b1::b0 = u32_state[index]
    ram[address + 3] = b3
    ram[address + 2] = b2
    ram[address + 1] = b1
    ram[address + 0] = b0
    address_updt = address + 4
}

fn print_state<u32_state>() {
    for i:u8 = 0; i<STATE_WIDTH; i = i + 1 {
    }
}
